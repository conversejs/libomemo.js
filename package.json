{
    "name": "libomemo.js",
    "repository": "github:conversejs/libomemo.js",
    "version": "2.0.2",
    "license": "GPL-3.0",
    "type": "module",
    "main": "./dist/libomemo.umd.js",
    "module": "./dist/libomemo.esm.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/libomemo.esm.js",
            "require": "./dist/libomemo.umd.js"
        }
    },
    "scripts": {
        "build": "npm run compile && npm run bundle",
        "build:dts": "tsc -p tsconfig.dts.json",
        "bundle": "npm run build:dts && rollup -c",
        "check": "npm run bundle && npm run lint && npm run test",
        "clean": "rm -rf node_modules",
        "compile": "node scripts/compile.js",
        "dev": "rollup -c -w",
        "dist": "npm run build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" rollup.config.js vitest.config.ts",
        "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" rollup.config.js vitest.config.ts",
        "lint:fix": "eslint --fix \"src/**/*.ts\" \"test/**/*.ts\" rollup.config.js vitest.config.ts",
        "prepublishOnly": "npm run build",
        "proto": "pbjs -t static-module -w es6 --keep-case --force-number --no-verify --no-convert --no-delimited -o src/generated/protocol.js protos/WhisperTextProtocol.proto protos/push.proto protos/OMEMO.proto && pbts -o src/generated/protocol.d.ts src/generated/protocol.js && sed -i '/^import Long = require(\"long\");$/d' src/generated/protocol.d.ts",
        "test": "npm run test:node && npm run test:browser",
        "test:node": "vitest run",
        "test:browser": "vitest run --config vitest.browser.config.ts",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "protobufjs": "^8.0.0"
    },
    "devDependencies": {
        "@rollup/plugin-alias": "^6.0.0",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.1.2",
        "@types/chai": "^5.2.3",
        "@types/node": "^22.19.19",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.59.3",
        "@vitest/browser": "^4.1.7",
        "@vitest/browser-playwright": "^4.1.7",
        "chai": "^6.2.2",
        "esbuild": "^0.28.0",
        "eslint": "^10.6.0",
        "globals": "^17.6.0",
        "playwright": "^1.60.0",
        "prettier": "^3.7.4",
        "protobufjs-cli": "^2.5.5",
        "rollup": "^4.60.3",
        "rollup-plugin-dts": "^6.4.1",
        "rollup-plugin-esbuild": "^6.2.1",
        "rollup-plugin-string": "^3.0.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    }
}
